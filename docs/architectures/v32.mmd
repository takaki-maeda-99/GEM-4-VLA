    end

    HS --> SLICE_HA
    HS --> SLICE_HT
    WRIST_LAST --> WRIST_PROJ
    WRIST_PROJ --> H_W
    PROPRIO --> PROP_PROJ
    PROP_PROJ --> P

    %% ============= ACTION HEAD =============
    subgraph ActionHead["🔥 Action head · 24 × MLPResNetBlock_Pro (trainable, no warmup)"]
        X_INIT["x_init = zeros(B, 8, 7×1536=10752)<br/>+ 0.02·randn (training only)"]
        LN1_FC1["LN(10752) + fc1(10752→1536) + ReLU<br/>→ (B, 8, 1536)"]
        POOL_CONCAT["if h_w is not None and bridge OFF:<br/>x = cat([x, h_w], dim=1)<br/>→ (B, 8+256=264, 1536)"]
        BLOCK["block_i (× 24) MLPResNetBlock_Pro:<br/>3-stream attention<br/>q from x; k_self/v_self from x<br/>k_adapter/v_adapter from h_a[:, i+1] ⊕ p<br/>k_task/v_task from h_t[:, i+1] (512 tokens)<br/>RoPE on q + each k_*<br/>tanh(g_task) gating on task stream<br/>+ FFN (LN + Linear D→D + ReLU)<br/>NO wrist branch (use_wrist_bridge=False)"]
        TRIM["x[:, :8, :] (drop pool tokens)"]
        LN2_FC2["LN(1536) + fc2(1536→7) → (B, 8, 7)<br/>action_decoder = Passthrough"]
    end

    X_INIT --> LN1_FC1 --> POOL_CONCAT --> BLOCK --> TRIM --> LN2_FC2
    H_W --> POOL_CONCAT
    SLICE_HA --> BLOCK
    SLICE_HT --> BLOCK
    P --> BLOCK

    %% ============= OUTPUT =============
    LN2_FC2 --> PRED["predicted action chunk<br/>(B, 8, 7)<br/>Q99-normalized"]
