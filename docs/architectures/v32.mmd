    subgraph BelowLLM["🔥 Below-LLM action head input prep (trainable, no warmup)"]
        SLICE_HA["slice action positions<br/>h_a (B, 25, 64, 1536)"]
        SLICE_HT["slice vision positions<br/>h_t (B, 25, 512, 1536)"]
